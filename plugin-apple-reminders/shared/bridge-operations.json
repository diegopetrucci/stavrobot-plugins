{
  "contract_version": "2026-06-30",
  "bridge": {
    "endpoint": {
      "config_key": "bridge_url",
      "url_schemes": [
        "http",
        "https"
      ],
      "method": "POST",
      "content_type": "application/json"
    },
    "authentication": {
      "type": "bearer",
      "config_key": "bridge_token",
      "header": "Authorization"
    },
    "deny_by_default": true,
    "explicitly_rejected": [
      "unknown operations",
      "arbitrary host command execution",
      "shell passthrough",
      "general filesystem access",
      "unsupported generic Apple Reminders fields"
    ]
  },
  "request_envelope": {
    "type": "object",
    "required": [
      "contract_version",
      "operation",
      "payload"
    ],
    "additionalProperties": false,
    "properties": {
      "contract_version": {
        "type": "string",
        "const": "2026-06-30"
      },
      "operation": {
        "type": "string",
        "enum": [
          "status.get",
          "status.doctor",
          "lists.list",
          "lists.create",
          "lists.update",
          "lists.delete",
          "reminders.list",
          "reminders.search",
          "reminders.info",
          "reminders.export",
          "reminders.create",
          "reminders.update",
          "reminders.complete",
          "reminders.uncomplete",
          "reminders.delete",
          "reminders.bulk_update",
          "reminders.bulk_complete",
          "reminders.bulk_delete",
          "reminders.bulk_move"
        ]
      },
      "payload": {
        "type": "object"
      },
      "request_id": {
        "type": "string",
        "description": "Optional caller-generated id echoed by the bridge in its response."
      },
      "dry_run": {
        "type": "boolean",
        "description": "Optional preview flag. Supported by reminders.complete, reminders.delete, reminders.bulk_complete when completed=true, and reminders.bulk_delete; other mutation operations reject it."
      }
    }
  },
  "response_envelope": {
    "type": "object",
    "required": [
      "ok",
      "operation"
    ],
    "additionalProperties": false,
    "properties": {
      "ok": {
        "type": "boolean"
      },
      "operation": {
        "type": "string"
      },
      "request_id": {
        "type": "string"
      },
      "result": {
        "type": "object",
        "description": "Present when ok is true."
      },
      "error": {
        "type": "object",
        "description": "Present when ok is false.",
        "required": [
          "code",
          "message"
        ],
        "additionalProperties": false,
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "details": {
            "type": "object"
          }
        }
      }
    }
  },
  "shared_payload_models": {
    "empty": {
      "type": "object",
      "additionalProperties": false,
      "description": "Operation takes no payload fields."
    },
    "list_reference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "list": {
          "type": "string",
          "description": "Reminder list title/name accepted by remindctl."
        },
        "list_id": {
          "type": "string",
          "description": "Reminder list id accepted by remindctl."
        }
      },
      "description": "Provide list or list_id when an operation targets one list."
    },
    "list_create": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Reminder list title."
        },
        "name": {
          "type": "string",
          "description": "Alias for title when matching remindctl list naming."
        }
      },
      "anyOf": [
        {
          "required": [
            "title"
          ]
        },
        {
          "required": [
            "name"
          ]
        }
      ]
    },
    "list_rename": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "list": {
          "type": "string",
          "description": "Current list title/name."
        },
        "list_id": {
          "type": "string",
          "description": "Current list id."
        },
        "rename": {
          "type": "string",
          "description": "New list title/name."
        }
      },
      "required": [
        "rename"
      ],
      "anyOf": [
        {
          "required": [
            "list"
          ]
        },
        {
          "required": [
            "list_id"
          ]
        }
      ]
    },
    "list_delete": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "list": {
          "type": "string",
          "description": "List title/name to delete."
        },
        "list_id": {
          "type": "string",
          "description": "List id to delete."
        },
        "force": {
          "type": "boolean",
          "description": "Explicit confirmation for destructive list deletion; non-dry-run delete requests must set this to true."
        }
      },
      "anyOf": [
        {
          "required": [
            "list"
          ]
        },
        {
          "required": [
            "list_id"
          ]
        }
      ]
    },
    "reminder_locator": {
      "type": "object",
      "required": [
        "reminder_id"
      ],
      "additionalProperties": false,
      "properties": {
        "reminder_id": {
          "type": "string"
        }
      }
    },
    "reminder_filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filter": {
          "type": "string",
          "enum": [
            "today",
            "tomorrow",
            "week",
            "overdue",
            "upcoming",
            "open",
            "completed",
            "all",
            "date"
          ],
          "description": "remindctl read filter. Use date with the date field."
        },
        "date": {
          "type": "string",
          "description": "Date value for the date filter, using the format accepted by remindctl."
        },
        "list": {
          "type": "string",
          "description": "Optional list title/name narrowing."
        },
        "list_id": {
          "type": "string",
          "description": "Optional list id narrowing."
        }
      }
    },
    "reminder_list_query": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filters": {
          "$ref": "#/shared_payload_models/reminder_filters"
        }
      }
    },
    "reminder_search_query": {
      "type": "object",
      "required": [
        "query"
      ],
      "additionalProperties": false,
      "properties": {
        "query": {
          "type": "string",
          "description": "Search query passed to remindctl."
        },
        "completed": {
          "type": "boolean",
          "description": "Whether completed reminders should be included or targeted, matching remindctl search behavior."
        },
        "list": {
          "type": "string",
          "description": "Optional list title/name narrowing."
        },
        "list_id": {
          "type": "string",
          "description": "Optional list id narrowing."
        }
      }
    },
    "reminder_export_query": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {
          "type": "string",
          "enum": [
            "json",
            "csv"
          ]
        },
        "list": {
          "type": "string",
          "description": "Optional list title/name narrowing supported by remindctl export."
        },
        "list_id": {
          "type": "string",
          "description": "Optional list id narrowing supported by remindctl export."
        }
      },
      "required": [
        "format"
      ]
    },
    "recurrence_rule": {
      "description": "remindctl repeat rule: daily, weekly, biweekly, monthly, yearly, or every N days/weeks/months/years.",
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "daily",
            "weekly",
            "biweekly",
            "monthly",
            "yearly"
          ]
        },
        {
          "type": "string",
          "pattern": "^every [1-9][0-9]* (day|days|week|weeks|month|months|year|years)$"
        }
      ]
    },
    "location_trigger": {
      "type": "object",
      "required": [
        "location"
      ],
      "additionalProperties": false,
      "properties": {
        "location": {
          "type": "string",
          "description": "Address or place string passed to remindctl location arguments."
        },
        "leaving": {
          "type": "boolean",
          "description": "Use leaving behavior instead of the default arriving behavior."
        },
        "radius_meters": {
          "type": "number",
          "minimum": 1,
          "description": "Optional location trigger radius in meters."
        }
      }
    },
    "priority": {
      "type": "string",
      "enum": [
        "none",
        "low",
        "medium",
        "high"
      ]
    },
    "reminder_patch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "due": {
          "type": "string",
          "description": "Due date/time value accepted by remindctl."
        },
        "alarm": {
          "type": "string",
          "description": "Alarm date/time value accepted by remindctl."
        },
        "repeat": {
          "$ref": "#/shared_payload_models/recurrence_rule"
        },
        "no_repeat": {
          "type": "boolean"
        },
        "priority": {
          "$ref": "#/shared_payload_models/priority"
        },
        "list": {
          "type": "string",
          "description": "Destination list title/name."
        },
        "list_id": {
          "type": "string",
          "description": "Destination list id."
        },
        "complete": {
          "type": "boolean"
        },
        "incomplete": {
          "type": "boolean"
        },
        "clear_due": {
          "type": "boolean"
        },
        "clear_alarm": {
          "type": "boolean"
        },
        "clear_url": {
          "type": "boolean"
        }
      }
    },
    "reminder_create": {
      "type": "object",
      "required": [
        "title"
      ],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "due": {
          "type": "string",
          "description": "Due date/time value accepted by remindctl."
        },
        "alarm": {
          "type": "string",
          "description": "Alarm date/time value accepted by remindctl."
        },
        "repeat": {
          "$ref": "#/shared_payload_models/recurrence_rule"
        },
        "priority": {
          "$ref": "#/shared_payload_models/priority"
        },
        "list": {
          "type": "string",
          "description": "Destination list title/name."
        },
        "list_id": {
          "type": "string",
          "description": "Destination list id."
        },
        "location_trigger": {
          "$ref": "#/shared_payload_models/location_trigger"
        }
      }
    },
    "reminder_update": {
      "type": "object",
      "required": [
        "reminder_id",
        "patch"
      ],
      "additionalProperties": false,
      "properties": {
        "reminder_id": {
          "type": "string"
        },
        "patch": {
          "$ref": "#/shared_payload_models/reminder_patch"
        }
      }
    },
    "reminder_completion": {
      "type": "object",
      "required": [
        "reminder_id"
      ],
      "additionalProperties": false,
      "properties": {
        "reminder_id": {
          "type": "string"
        }
      }
    },
    "reminder_delete": {
      "type": "object",
      "required": [
        "reminder_id"
      ],
      "additionalProperties": false,
      "properties": {
        "reminder_id": {
          "type": "string"
        },
        "force": {
          "type": "boolean",
          "description": "Explicit confirmation for destructive reminder deletion; non-dry-run delete requests must set this to true."
        }
      }
    },
    "bulk_id_selection": {
      "type": "object",
      "required": [
        "reminder_ids"
      ],
      "additionalProperties": false,
      "properties": {
        "reminder_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "description": "Explicit reminder ids only; filters are intentionally not accepted for bulk operations."
        }
      }
    },
    "reminder_bulk_update": {
      "type": "object",
      "required": [
        "reminder_ids",
        "patch"
      ],
      "additionalProperties": false,
      "properties": {
        "reminder_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "patch": {
          "$ref": "#/shared_payload_models/reminder_patch"
        }
      }
    },
    "reminder_bulk_complete": {
      "type": "object",
      "required": [
        "reminder_ids"
      ],
      "additionalProperties": false,
      "properties": {
        "reminder_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "completed": {
          "type": "boolean",
          "description": "Defaults to true; use false for incomplete behavior if the bridge maps this operation to remindctl update."
        }
      }
    },
    "reminder_bulk_delete": {
      "type": "object",
      "required": [
        "reminder_ids"
      ],
      "additionalProperties": false,
      "properties": {
        "reminder_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "force": {
          "type": "boolean",
          "description": "Explicit confirmation for destructive reminder deletion; non-dry-run delete requests must set this to true."
        }
      }
    },
    "reminder_bulk_move": {
      "type": "object",
      "required": [
        "reminder_ids"
      ],
      "additionalProperties": false,
      "properties": {
        "reminder_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "target_list": {
          "type": "string",
          "description": "Destination list title/name."
        },
        "target_list_id": {
          "type": "string",
          "description": "Destination list id."
        }
      },
      "anyOf": [
        {
          "required": [
            "target_list"
          ]
        },
        {
          "required": [
            "target_list_id"
          ]
        }
      ]
    }
  },
  "operations": [
    {
      "name": "status.get",
      "family": "status",
      "payload_model": "empty",
      "result_model": "bridge_status",
      "summary": "Check bridge reachability, authentication, host identity, and remindctl capability advertisement."
    },
    {
      "name": "status.doctor",
      "family": "status",
      "payload_model": "empty",
      "result_model": "bridge_doctor",
      "summary": "Return agent-focused remindctl doctor diagnostics for permissions and host-side setup."
    },
    {
      "name": "lists.list",
      "family": "lists",
      "payload_model": "empty",
      "result_model": "list_records",
      "summary": "List reminder lists available through remindctl."
    },
    {
      "name": "lists.create",
      "family": "lists",
      "payload_model": "list_create",
      "result_model": "list_record",
      "summary": "Create a reminders list by title/name."
    },
    {
      "name": "lists.update",
      "family": "lists",
      "payload_model": "list_rename",
      "result_model": "list_record",
      "summary": "Rename a reminders list by title/name or list id."
    },
    {
      "name": "lists.delete",
      "family": "lists",
      "payload_model": "list_delete",
      "result_model": "mutation_receipt",
      "summary": "Delete a reminders list by title/name or list id, optionally using force."
    },
    {
      "name": "reminders.list",
      "family": "reminders",
      "payload_model": "reminder_list_query",
      "result_model": "reminder_records",
      "summary": "List reminders with remindctl filters such as today, tomorrow, week, overdue, upcoming, open, completed, all, or date."
    },
    {
      "name": "reminders.search",
      "family": "reminders",
      "payload_model": "reminder_search_query",
      "result_model": "reminder_records",
      "summary": "Search reminders by query with optional completed and list/list_id narrowing."
    },
    {
      "name": "reminders.info",
      "family": "reminders",
      "payload_model": "reminder_locator",
      "result_model": "reminder_record",
      "summary": "Show detailed information for one reminder by id or id prefix."
    },
    {
      "name": "reminders.export",
      "family": "reminders",
      "payload_model": "reminder_export_query",
      "result_model": "export_descriptor",
      "summary": "Export reminders in remindctl-supported json or csv format."
    },
    {
      "name": "reminders.create",
      "family": "reminders",
      "payload_model": "reminder_create",
      "result_model": "reminder_record",
      "summary": "Create a reminder with remindctl-supported fields, recurrence, and location trigger metadata."
    },
    {
      "name": "reminders.update",
      "family": "reminders",
      "payload_model": "reminder_update",
      "result_model": "reminder_record",
      "summary": "Update a reminder through the shared remindctl-supported reminder patch model."
    },
    {
      "name": "reminders.complete",
      "family": "reminders",
      "payload_model": "reminder_completion",
      "result_model": "reminder_record",
      "summary": "Mark a reminder complete."
    },
    {
      "name": "reminders.uncomplete",
      "family": "reminders",
      "payload_model": "reminder_completion",
      "result_model": "reminder_record",
      "summary": "Mark a reminder incomplete again."
    },
    {
      "name": "reminders.delete",
      "family": "reminders",
      "payload_model": "reminder_delete",
      "result_model": "mutation_receipt",
      "summary": "Delete a reminder by id, requiring explicit force confirmation for non-dry-run execution."
    },
    {
      "name": "reminders.bulk_update",
      "family": "bulk",
      "payload_model": "reminder_bulk_update",
      "result_model": "bulk_mutation_receipt",
      "summary": "Apply the shared reminder patch model to an explicit list of reminder ids."
    },
    {
      "name": "reminders.bulk_complete",
      "family": "bulk",
      "payload_model": "reminder_bulk_complete",
      "result_model": "bulk_mutation_receipt",
      "summary": "Complete or uncomplete an explicit list of reminder ids."
    },
    {
      "name": "reminders.bulk_delete",
      "family": "bulk",
      "payload_model": "reminder_bulk_delete",
      "result_model": "bulk_mutation_receipt",
      "summary": "Delete an explicit list of reminder ids, requiring explicit force confirmation for non-dry-run execution."
    },
    {
      "name": "reminders.bulk_move",
      "family": "bulk",
      "payload_model": "reminder_bulk_move",
      "result_model": "bulk_mutation_receipt",
      "summary": "Move an explicit list of reminder ids into another list."
    }
  ]
}
